<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shikola Accountant - Fees Management</title>
    <link rel="icon" type="image/png" href="../../assets/images/favicon.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="/config/config.js" defer></script>
    <script src="/shared-assets/js/dashboard-theme.js" defer></script>
    <script src="/shared-assets/js/shared-auth.js" defer></script>
    <script src="/shared-assets/js/shared-realtime-sync.js" defer></script>
    <script src="/shared-assets/js/shared-universal-notifications.js" defer></script>
    <script src="/shared-assets/js/shared-messages.js" defer></script>
    <script src="/shared-assets/js/button-functions.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" defer></script>
    <script src="accountant-functionality.js" defer></script>
    <script src="fees-management.js" defer></script>
    <script src="/shared-assets/js/shared-fee-banks.js" defer></script>
    <script src="/shared-assets/js/shared-school-profile.js" defer></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/frontend/assets/css/styles.css">
    <style>
        @media print {
            .page-break {
                page-break-after: always;
            }
            body {
                margin: 0;
                padding: 0;
            }
        }
        
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body class="dashboard-page">
    <div x-data="{ sidebarOpen: false, activeTab: 'fee-structure', chatOpen: false }" class="min-h-screen flex">
        <div class="flex-1 flex gap-4 lg:gap-8 w-full">
            <aside class="hidden lg:flex fixed inset-y-0 left-0 w-64 bg-white shadow-xl flex-col py-8 px-6 z-40 overflow-y-auto">
                <div class="flex justify-center mb-10">
                    <img src="../../assets/images/logo.png" alt="Shikola logo" class="h-15 w-20 rounded-2xl object-cover" data-school-logo>
                </div>

                <nav class="space-y-1 text-sm">
                    <a href="dashboard.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-chart-line"></i>
                        </span>
                        <span class="flex-1">Dashboard</span>
                    </a>
                    <a href="chart-of-accounts.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-sitemap"></i>
                        </span>
                        <span class="flex-1">Chart of Accounts</span>
                    </a>
                    <a href="income-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-arrow-down"></i>
                        </span>
                        <span class="flex-1">Income Management</span>
                    </a>
                    <a href="expense-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-arrow-up"></i>
                        </span>
                        <span class="flex-1">Expense Management</span>
                    </a>
                    <a href="fees-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-emerald-400 to-teal-500 text-white shadow-md">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-graduation-cap"></i>
                        </span>
                        <span class="flex-1">Fees Management</span>
                    </a>
                    <a href="salary-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-money-bill-wave"></i>
                        </span>
                        <span class="flex-1">Salary Management</span>
                    </a>
                    <a href="bank-reconciliation.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-university"></i>
                        </span>
                        <span class="flex-1">Bank Reconciliation</span>
                    </a>
                    <a href="financial-reports.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-file-invoice"></i>
                        </span>
                        <span class="flex-1">Financial Reports</span>
                    </a>
                    <a href="budget-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-calculator"></i>
                        </span>
                        <span class="flex-1">Budget Management</span>
                    </a>
                    <a href="audit-trail.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-history"></i>
                        </span>
                        <span class="flex-1">Audit Trail</span>
                    </a>
                    <a href="profile.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                        <span class="w-6 flex justify-center">
                            <i class="fas fa-user"></i>
                        </span>
                        <span class="flex-1">Profile</span>
                    </a>
                </nav>

                <div class="mt-auto pt-8 border-t border-slate-100">
                    <div class="flex items-center justify-center px-2">
                        <a href="../../public/index.html" data-action="logout" class="flex items-center gap-2 px-3 py-2 rounded-xl text-red-500 hover:bg-red-50 text-xs font-medium">
                            <span class="w-5 flex justify-center">
                                <i class="fas fa-right-from-bracket"></i>
                            </span>
                            <span>Logout</span>
                        </a>
                    </div>
                </div>
            </aside>

            <div x-show="sidebarOpen" x-cloak class="fixed inset-0 z-50 flex lg:hidden">
                <div class="absolute inset-0 bg-slate-900/40" @click="sidebarOpen = false"></div>
                <aside class="relative h-full w-64 bg-white shadow-xl flex flex-col py-8 px-6">
                    <button type="button" class="absolute top-4 right-4 h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500" aria-label="Close navigation" @click="sidebarOpen = false">
                        <i class="fas fa-times text-sm"></i>
                    </button>
                    <div class="flex justify-center mb-10">
                        <img src="../../assets/images/logo.png" alt="Shikola logo" class="h-15 w-20 rounded-2xl object-cover" data-school-logo>
                    </div>

                    <nav class="space-y-1 text-sm">
                        <a href="dashboard.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-chart-line"></i>
                            </span>
                            <span class="flex-1">Dashboard</span>
                        </a>
                        <a href="chart-of-accounts.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-sitemap"></i>
                            </span>
                            <span class="flex-1">Chart of Accounts</span>
                        </a>
                        <a href="income-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-arrow-down"></i>
                            </span>
                            <span class="flex-1">Income Management</span>
                        </a>
                        <a href="expense-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-arrow-up"></i>
                            </span>
                            <span class="flex-1">Expense Management</span>
                        </a>
                        <a href="fees-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-gradient-to-r from-emerald-400 to-teal-500 text-white shadow-md">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-graduation-cap"></i>
                            </span>
                            <span class="flex-1">Fees Management</span>
                        </a>
                        <a href="salary-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-money-bill-wave"></i>
                            </span>
                            <span class="flex-1">Salary Management</span>
                        </a>
                        <a href="bank-reconciliation.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-university"></i>
                            </span>
                            <span class="flex-1">Bank Reconciliation</span>
                        </a>
                        <a href="financial-reports.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-file-invoice"></i>
                            </span>
                            <span class="flex-1">Financial Reports</span>
                        </a>
                        <a href="budget-management.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-calculator"></i>
                            </span>
                            <span class="flex-1">Budget Management</span>
                        </a>
                        <a href="audit-trail.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-history"></i>
                            </span>
                            <span class="flex-1">Audit Trail</span>
                        </a>
                        <a href="profile.html" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-500 hover:bg-slate-50 transition">
                            <span class="w-6 flex justify-center">
                                <i class="fas fa-user"></i>
                            </span>
                            <span class="flex-1">Profile</span>
                        </a>
                    </nav>

                    <div class="mt-auto pt-8 border-t border-slate-100">
                        <div class="flex items-center justify-center px-2">
                            <a href="../../public/index.html" data-action="logout" class="flex items-center gap-2 px-3 py-2 rounded-xl text-red-500 hover:bg-red-50 text-xs font-medium">
                                <span class="w-5 flex justify-center">
                                    <i class="fas fa-right-from-bracket"></i>
                                </span>
                                <span>Logout</span>
                            </a>
                        </div>
                    </div>
                </aside>
            </div>

            <main class="flex-1 w-full px-3 sm:px-6 py-6 lg:pl-72">
                <div class="bg-white rounded-3xl shadow-xl px-4 sm:px-6 lg:px-8 py-5 lg:py-7 h-full flex flex-col">
                    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4 sticky top-0 z-30 bg-white/95 backdrop-blur border-b border-slate-100 pb-3">
                        <div class="flex items-center justify-center w-full lg:w-auto lg:justify-start gap-3">
                            <button type="button" data-action="toggle-menu" class="lg:hidden fixed top-4 left-4 z-50 h-9 w-9 rounded-xl bg-white shadow-lg flex items-center justify-center text-slate-600 hover:bg-slate-50 transition" aria-label="Open navigation" @click="sidebarOpen = true">
                                <i class="fas fa-bars"></i>
                            </button>
                            <img src="../../assets/images/logo.png" alt="Shikola logo" class="h-14 w-auto rounded-2xl lg:hidden">
                            <div class="hidden lg:block">
                                <h1 class="text-2xl sm:text-3xl font-semibold text-slate-800">Fees Management</h1>
                                <p class="text-xs sm:text-sm text-slate-400 mt-1 hidden sm:block">Manage student fees, invoices, and payment collections.</p>
                            </div>
                        </div>
                        <div class="hidden xl:flex items-center gap-3">
                            <div class="hidden sm:flex items-center bg-slate-50 px-3 py-2 rounded-xl border border-slate-100 w-56">
                                <i class="fas fa-search text-slate-400 text-sm mr-2"></i>
                                <input type="text" placeholder="Search students..." class="bg-transparent text-sm text-slate-600 placeholder-slate-400 focus:outline-none flex-1">
                            </div>
                            <button class="h-9 w-9 rounded-xl bg-slate-50 flex items-center justify-center text-slate-400 hover:text-slate-600" type="button" aria-label="Notifications" data-action="notifications">
                                <i class="far fa-bell"></i>
                            </button>
                            <div class="relative" x-data="{ open: false }" @click.outside="open = false">
                                <button type="button" class="flex items-center gap-2 pl-1" @click="open = !open">
                                    <div class="h-9 w-9 rounded-full bg-gradient-to-tr from-emerald-400 to-teal-500 text-white flex items-center justify-center text-sm">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <div class="hidden sm:block text-left">
                                        <div class="text-xs font-medium text-slate-700">Accountant</div>
                                        <div class="text-[10px] text-slate-400">Financial Officer</div>
                                    </div>
                                </button>
                                <div
                                    x-show="open"
                                    x-cloak
                                    class="absolute right-0 mt-2 w-44 rounded-xl bg-white shadow-lg border border-slate-100 py-1 text-xs text-slate-600 z-30">
                                    <a href="profile.html" class="flex items-center gap-2 px-3 py-1.5 hover:bg-slate-50">
                                        <span class="w-4 flex justify-center text-slate-400">
                                            <i class="fas fa-id-badge"></i>
                                        </span>
                                        <span>Profile</span>
                                    </a>
                                    <div class="my-1 border-t border-slate-100"></div>
                                    <a href="../../public/index.html" data-action="logout" class="flex items-center gap-2 px-3 py-1.5 hover:bg-red-50 text-red-500">
                                        <span class="w-4 flex justify-center">
                                            <i class="fas fa-right-from-bracket"></i>
                                        </span>
                                        <span>Logout</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fee Overview Cards -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6 mt-6">
                        <div class="rounded-2xl bg-gradient-to-tr from-emerald-400 to-teal-500 text-white p-5 flex items-center justify-between shadow-md">
                            <div>
                                <div class="text-xs uppercase tracking-wide text-emerald-100/90">Total Collected</div>
                                <div class="mt-2 text-2xl font-semibold leading-none" data-card="total-collected">K 0.00</div>
                                <div class="mt-1 text-xs text-emerald-100/80" data-summary="collection-status">No collections yet</div>
                            </div>
                            <div class="h-12 w-12 rounded-2xl bg-white/20 flex items-center justify-center">
                                <i class="fas fa-hand-holding-dollar text-xl"></i>
                            </div>
                        </div>
                        <div class="rounded-2xl bg-gradient-to-tr from-orange-400 to-red-500 text-white p-5 flex items-center justify-between shadow-md">
                            <div>
                                <div class="text-xs uppercase tracking-wide text-orange-100/90">Outstanding</div>
                                <div class="mt-2 text-2xl font-semibold leading-none" data-card="outstanding">K 0.00</div>
                                <div class="mt-1 text-xs text-orange-100/80" data-summary="outstanding-status">No outstanding fees</div>
                            </div>
                            <div class="h-12 w-12 rounded-2xl bg-white/20 flex items-center justify-center">
                                <i class="fas fa-exclamation-triangle text-xl"></i>
                            </div>
                        </div>
                        <div class="rounded-2xl bg-gradient-to-tr from-blue-400 to-indigo-500 text-white p-5 flex items-center justify-between shadow-md">
                            <div>
                                <div class="text-xs uppercase tracking-wide text-blue-100/90">Pending Invoices</div>
                                <div class="mt-2 text-2xl font-semibold leading-none" data-card="pending-invoices">0</div>
                                <div class="mt-1 text-xs text-blue-100/80" data-summary="pending-status">No pending invoices</div>
                            </div>
                            <div class="h-12 w-12 rounded-2xl bg-white/20 flex items-center justify-center">
                                <i class="fas fa-file-invoice text-xl"></i>
                            </div>
                        </div>
                        <div class="rounded-2xl bg-gradient-to-tr from-purple-400 to-violet-500 text-white p-5 flex items-center justify-between shadow-md">
                            <div>
                                <div class="text-xs uppercase tracking-wide text-purple-100/90">Collection Rate</div>
                                <div class="mt-2 text-2xl font-semibold leading-none" data-card="collection-rate">0%</div>
                                <div class="mt-1 text-xs text-purple-100/80" data-summary="rate-status">No data available</div>
                            </div>
                            <div class="h-12 w-12 rounded-2xl bg-white/20 flex items-center justify-center">
                                <i class="fas fa-chart-line text-xl"></i>
                            </div>
                        </div>
                    </div>

                    <div class="mt-6">
                        <div class="flex gap-2 overflow-x-auto pb-1 -mx-1 px-1 text-xs sm:text-sm">
                            <button type="button" @click="activeTab = 'fee-structure'" :class="activeTab === 'fee-structure' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-list-alt"></i></span>
                                <span>Fee Structure</span>
                            </button>
                            <button type="button" @click="activeTab = 'generate-invoice'" :class="activeTab === 'generate-invoice' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-plus-circle"></i></span>
                                <span>Generate Invoice</span>
                            </button>
                            <button type="button" @click="activeTab = 'collect-fees'" :class="activeTab === 'collect-fees' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-cash-register"></i></span>
                                <span>Collect Fees</span>
                            </button>
                            <button type="button" @click="activeTab = 'fee-receipts'" :class="activeTab === 'fee-receipts' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-receipt"></i></span>
                                <span>Fee Receipts</span>
                            </button>
                            <button type="button" @click="activeTab = 'defaulters'" :class="activeTab === 'defaulters' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-user-clock"></i></span>
                                <span>Fee Defaulters</span>
                            </button>
                            <button type="button" @click="activeTab = 'payment-history'" :class="activeTab === 'payment-history' ? 'bg-slate-900 text-white shadow-sm' : 'bg-slate-50 text-slate-500 hover:bg-slate-100'" class="flex items-center gap-2 px-3 py-2 rounded-full whitespace-nowrap border border-slate-200">
                                <span class="w-5 flex justify-center"><i class="fas fa-history"></i></span>
                                <span>Payment History</span>
                            </button>
                        </div>
                    </div>

                    <div class="mt-6 flex-1 space-y-6 text-sm">
                        <!-- Fee Structure -->
                        <section x-show="activeTab === 'fee-structure'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Fee Structure</div>
                                                <div class="text-xs text-slate-400 mt-1">Define fee types and amounts for different grades</div>
                                            </div>
                                            <button type="button" id="btn-add-fee-type" class="px-3 py-1.5 rounded-xl bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700">
                                                <i class="fas fa-plus mr-1"></i> Add Fee Type
                                            </button>
                                        </div>
                                        <div class="rounded-2xl border border-slate-100 overflow-hidden text-xs" data-fee-structures-list>
                                            <div class="hidden md:grid grid-cols-12 bg-slate-50 px-4 py-2.5 text-[11px] font-medium text-slate-500">
                                                <div class="col-span-3">Fee Type</div>
                                                <div class="col-span-2">Grade Level</div>
                                                <div class="col-span-2">Amount</div>
                                                <div class="col-span-2">Frequency</div>
                                                <div class="col-span-2">Status</div>
                                                <div class="col-span-1">Actions</div>
                                            </div>
                                            <div class="text-center py-12">
                                                <i class="fas fa-money-bill-wave text-4xl text-slate-300 mb-3"></i>
                                                <p class="text-sm text-slate-500">Loading fee structures...</p>
                                                <p class="text-xs text-slate-400 mt-1">Please wait while we load your fee structures</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Generate Invoice -->
                        <section x-show="activeTab === 'generate-invoice'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Generate Fee Invoice</div>
                                                <div class="text-xs text-slate-400 mt-1">Create and send fee invoices to pupils, classes or families, including tuition, admission, transport and other fee items.</div>
                                            </div>
                                        </div>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Select Pupils *</label>
                                                <select id="invoice-pupils-select" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Select option" title="Select option">
                                                    <option value="">Select pupils or class</option>
                                                    <option value="individual">Individual Pupils</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Select Class</label>
                                                <select id="invoice-class-select" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Select class" title="Select class">
                                                    <option value="">All Classes</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Search Pupils</label>
                                                <div class="relative">
                                                    <input type="text" id="pupil-search-input" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" placeholder="Search pupils by name or ID..." aria-label="Search pupils" title="Search pupils">
                                                    <button type="button" id="btn-pupil-search" class="absolute right-2 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                                        <i class="fas fa-search text-xs"></i>
                                                    </button>
                                                </div>
                                                <div id="pupil-search-results" class="absolute left-0 right-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-lg text-[11px] text-slate-700 max-h-56 overflow-y-auto hidden z-20"></div>
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Invoice Period *</label>
                                                <select id="invoice-period-select" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Select option" title="Select option">
                                                    <option value="">Select period</option>
                                                </select>
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Due Date *</label>
                                                <input id="invoice-due-date" type="date" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Invoice due date" title="Invoice due date">
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1">Payment Methods</label>
                                                <div class="space-y-2">
                                                    <label class="flex items-center gap-2 text-xs">
                                                        <input type="checkbox" checked class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-400">
                                                        <span class="text-slate-600">Cash</span>
                                                    </label>
                                                    <label class="flex items-center gap-2 text-xs">
                                                        <input type="checkbox" checked class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-400">
                                                        <span class="text-slate-600">Bank Transfer</span>
                                                    </label>
                                                    <label class="flex items-center gap-2 text-xs">
                                                        <input type="checkbox" checked class="rounded border-slate-300 text-emerald-600 focus:ring-emerald-400">
                                                        <span class="text-slate-600">Mobile Money</span>
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                                            <div class="text-xs font-medium text-slate-700 mb-3">Fee Items to Include</div>
                                            <div class="space-y-2" data-fee-items-container>
                                                <div class="text-center py-4 text-slate-500">
                                                    <i class="fas fa-spinner fa-spin text-2xl mb-2"></i>
                                                    <p>Loading fee items...</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="rounded-2xl border border-slate-100 overflow-hidden text-xs" data-invoices-list>
                                            <div class="hidden md:grid grid-cols-12 bg-slate-50 px-4 py-2.5 text-[11px] font-medium text-slate-500">
                                                <div class="col-span-3">Invoice #</div>
                                                <div class="col-span-2">Student</div>
                                                <div class="col-span-2">Amount</div>
                                                <div class="col-span-2">Due Date</div>
                                                <div class="col-span-2">Status</div>
                                                <div class="col-span-1">Actions</div>
                                            </div>
                                            <div class="text-center py-12">
                                                <i class="fas fa-file-invoice text-4xl text-slate-300 mb-3"></i>
                                                <p class="text-sm text-slate-500">Loading invoices...</p>
                                                <p class="text-xs text-slate-400 mt-1">Please wait while we load your invoices</p>
                                            </div>
                                        </div>
                                        <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
                                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                                                <div>
                                                    <div class="text-slate-500" data-summary="pupil-count">Number of Pupils</div>
                                                    <div class="font-semibold text-slate-800" data-card="pupil-count">0</div>
                                                </div>
                                                <div>
                                                    <div class="text-slate-500" data-summary="total-amount">Total Amount</div>
                                                    <div class="font-semibold text-emerald-600" data-card="total-amount">K 0.00</div>
                                                </div>
                                                <div>
                                                    <div class="text-slate-500" data-summary="due-date">Due Date</div>
                                                    <div class="font-semibold text-slate-800" data-card="due-date">Not set</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="flex justify-end gap-2">
                                            <button id="btn-save-fee-invoice-draft" type="button" class="px-4 py-2 rounded-xl border border-slate-200 bg-white text-xs text-slate-600 hover:bg-slate-50">Save Draft</button>
                                            <button id="btn-generate-fee-invoice" type="button" class="px-4 py-2 rounded-xl bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700">Generate Invoice</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Collect Fees -->
                        <section x-show="activeTab === 'collect-fees'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Collect Fees</div>
                                                <div class="text-xs text-slate-400 mt-1">Record payments against fee invoices, choose payment method and date, and update each invoice as Paid or Partially Paid.</div>
                                            </div>
                                            <div class="relative">
                                                <input type="text" id="student-name-id" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Student Name/ID" title="Enter student name or ID" placeholder="Search student...">
                                                <button class="absolute right-2 top-1/2 transform -translate-y-1/2 text-slate-400 hover:text-slate-600" aria-label="Search button">
                                                    <i class="fas fa-search text-xs"></i>
                                                </button>
                                                <div id="student-search-suggestions" class="absolute left-0 right-0 mt-1 bg-white border border-slate-200 rounded-xl shadow-lg text-[11px] text-slate-700 max-h-56 overflow-y-auto hidden z-20"></div>
                                            </div>
                                        </div>
                                        <div>
                                            <label class="block text-[11px] font-medium text-slate-600 mb-1" for="payment-method">Payment Method *</label>
                                            <select id="payment-method" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Select payment method" title="Select payment method">
                                                <option value="">Select payment method</option>
                                                <option value="cash">Cash</option>
                                                <option value="bank-transfer">Bank Transfer</option>
                                                <option value="mobile-money-airtel">Mobile Money - Airtel</option>
                                                <option value="mobile-money-mtn">Mobile Money - MTN</option>
                                                <option value="cheque">Cheque</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-[11px] font-medium text-slate-600 mb-1" for="payment-bank">Bank Account</label>
                                            <select id="payment-bank" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600 focus:outline-none focus:ring-1 focus:ring-emerald-400" data-fee-bank-select aria-label="Select bank account" title="Select bank account">
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-[11px] font-medium text-slate-600 mb-1" for="amount-paid">Amount Paid *</label>
                                                <input type="number" id="amount-paid" step="0.01" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Amount Paid" title="Enter amount paid" placeholder="0.00">
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1" for="payment-date">Payment Date *</label>
                                                <input type="date" id="payment-date" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Payment Date" title="Enter payment date">
                                            </div>
                                            <div>
                                                <label class="block text-[11px] font-medium text-slate-600 mb-1" for="reference-number">Reference Number</label>
                                                <input type="text" id="reference-number" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-emerald-400" aria-label="Reference Number" title="Enter transaction reference" placeholder="Transaction reference">
                                            </div>
                                        </div>
                                        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
                                            <div class="text-xs font-medium text-slate-700 mb-3">Outstanding Fees</div>
                                            <div id="collect-outstanding-list" class="space-y-2">
                                                <div class="text-center py-4 text-slate-500">
                                                    <i class="fas fa-search text-2xl mb-2"></i>
                                                    <p>Search for a student to view outstanding fees</p>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
                                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-xs">
                                                <div>
                                                    <div class="text-slate-500">Total Due</div>
                                                    <div class="font-semibold text-slate-800" data-fees-total-due>K 0.00</div>
                                                </div>
                                                <div>
                                                    <div class="text-slate-500">Amount Paid</div>
                                                    <div class="font-semibold text-emerald-600" data-fees-amount-paid>K 0.00</div>
                                                </div>
                                                <div>
                                                    <div class="text-slate-500">Balance</div>
                                                    <div class="font-semibold text-orange-600" data-fees-balance>K 0.00</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="flex justify-end gap-2">
                                            <button type="button" class="px-4 py-2 rounded-xl border border-slate-200 bg-white text-xs text-slate-600 hover:bg-slate-50">Clear</button>
                                            <button id="btn-process-fee-payment" type="button" class="px-4 py-2 rounded-xl bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700">Process Payment</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Fee Defaulters -->
                        <section x-show="activeTab === 'defaulters'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Fee Defaulters</div>
                                                <div class="text-xs text-slate-400 mt-1">Students with outstanding fee payments</div>
                                            </div>
                                            <div class="flex gap-2">
                                                <button class="px-3 py-1.5 rounded-xl bg-blue-600 text-white text-xs font-medium hover:bg-blue-700" onclick="sendReminders()">
                                                    <i class="fas fa-envelope mr-1"></i> Send Reminders
                                                </button>
                                                <button class="px-3 py-1.5 rounded-xl bg-orange-600 text-white text-xs font-medium hover:bg-orange-700" onclick="exportData('pdf', 'defaulters')">
                                                    <i class="fas fa-file-export mr-1"></i> Export List
                                                </button>
                                            </div>
                                        </div>
                                        <div class="rounded-2xl border border-slate-100 overflow-hidden text-xs" data-defaulters-list>
                                            <div class="hidden md:grid grid-cols-12 bg-slate-50 px-4 py-2.5 text-[11px] font-medium text-slate-500">
                                                <div class="col-span-3">Student</div>
                                                <div class="col-span-2">Grade</div>
                                                <div class="col-span-2">Outstanding</div>
                                                <div class="col-span-2">Days Overdue</div>
                                                <div class="col-span-2">Last Contact</div>
                                                <div class="col-span-1">Select</div>
                                            </div>
                                            <div class="text-center py-12">
                                                <i class="fas fa-user-clock text-4xl text-slate-300 mb-3"></i>
                                                <p class="text-sm text-slate-500">Loading fee defaulters...</p>
                                                <p class="text-xs text-slate-400 mt-1">Please wait while we load defaulter information</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Fee Receipts -->
                        <section x-show="activeTab === 'fee-receipts'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Fee Receipts</div>
                                                <div class="text-xs text-slate-400 mt-1">View and print fee payment receipts for pupils after collection, using the list of payments on the left.</div>
                                            </div>
                                            <div class="flex gap-2">
                                                <input type="text" placeholder="Search receipts..." class="px-3 py-1.5 rounded-xl border border-slate-200 bg-slate-50 text-xs">
                                                <button class="px-3 py-1.5 rounded-xl bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700" onclick="exportData('csv', 'receipts')">
                                                    <i class="fas fa-download mr-1"></i> Export CSV
                                                </button>
                                                <button class="px-3 py-1.5 rounded-xl bg-blue-600 text-white text-xs font-medium hover:bg-blue-700" onclick="exportData('pdf', 'receipts')">
                                                    <i class="fas fa-file-pdf mr-1"></i> Export PDF
                                                </button>
                                            </div>
                                        </div>
                                        <div class="rounded-2xl border border-slate-100 overflow-hidden text-xs">
                                            <div class="hidden md:grid grid-cols-12 bg-slate-50 px-4 py-2.5 text-[11px] font-medium text-slate-500">
                                                <div class="col-span-2">Receipt #</div>
                                                <div class="col-span-3">Student</div>
                                                <div class="col-span-2">Amount</div>
                                                <div class="col-span-2">Date</div>
                                                <div class="col-span-2">Method</div>
                                                <div class="col-span-1">Actions</div>
                                            </div>
                                            <div id="fee-receipts-list" class="divide-y divide-slate-100">
                                                <div class="text-center py-12">
                                                    <i class="fas fa-receipt text-4xl text-slate-300 mb-3"></i>
                                                    <p class="text-sm text-slate-500">No fee receipts recorded</p>
                                                    <p class="text-xs text-slate-400 mt-1">Fee receipts will appear here when payments are recorded</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Accountant Receipt Preview -->
                                    <div class="w-full lg:w-[420px] xl:w-[460px] space-y-4">
                                        <div class="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 text-xs" aria-label="Receipt preview (accountant copy)">
                                            <div class="flex items-start justify-between gap-3 border-b border-slate-200 pb-3">
                                                <div class="flex items-center gap-3">
                                                    <div class="h-10 w-12 rounded-xl bg-white border border-slate-200 flex items-center justify-center overflow-hidden">
                                                        <img src="../../assets/images/logo.png" alt="School logo" class="h-9 w-11 object-cover rounded-lg" data-school-logo>
                                                    </div>
                                                    <div>
                                                        <div class="text-sm font-semibold text-slate-800" data-school-name>Loading school name...</div>
                                                        <div class="text-[11px] text-slate-500" data-school-tagline>Loading school tagline...</div>
                                                        <div class="mt-1 text-[10px] text-slate-400 leading-snug">
                                                            <span data-school-address>Loading school address...</span><br>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="text-right">
                                                    <div class="text-[11px] font-semibold text-slate-700 tracking-wide">FEE PAYMENT RECEIPT</div>
                                                    <div class="text-[10px] text-slate-400 mt-1">Accountant Copy</div>
                                                    <div class="mt-2 flex flex-col items-end gap-1">
                                                        <div id="fee-receipt-qr" class="bg-white rounded-lg border border-slate-200 p-1"></div>
                                                        <div class="text-[9px] text-slate-400">Scan to verify</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mt-3 grid grid-cols-2 gap-3">
                                                <div class="space-y-1">
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Receipt #</span><br>
                                                        <span class="font-mono text-[11px] text-slate-800" data-receipt-field="number">RCP000000</span>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Pupil Name</span><br>
                                                        <span class="text-[11px] font-medium text-slate-800" data-receipt-field="pupil-name">-</span>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Class</span><br>
                                                        <span class="text-[11px] text-slate-800" data-receipt-field="class">-</span>
                                                    </div>
                                                </div>
                                                <div class="space-y-1 text-right">
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Date</span><br>
                                                        <span class="text-[11px] text-slate-800" data-receipt-field="date">-</span>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Payment Method</span><br>
                                                        <span class="text-[11px] text-slate-800" data-receipt-field="method">-</span>
                                                    </div>
                                                    <div>
                                                        <span class="text-[10px] text-slate-500">Amount Paid</span><br>
                                                        <span class="text-[12px] font-semibold text-emerald-600" data-receipt-field="amount">K 0.00</span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="mt-3 rounded-xl border border-slate-200 bg-white p-3 text-[10px] text-slate-600 hidden" data-receipt-bank-container>
                                                <div class="font-semibold text-slate-700 mb-1">Bank Account Details</div>
                                                <div>
                                                    <div><span class="text-slate-500">Bank:</span> <span class="text-slate-800 font-medium" data-receipt-bank-name>Not selected</span></div>
                                                    <div class="mt-0.5"><span class="text-slate-500">Account No:</span> <span class="text-slate-800 font-mono" data-receipt-bank-account>—</span></div>
                                                    <div class="mt-0.5 text-slate-500" data-receipt-bank-instructions></div>
                                                </div>
                                            </div>

                                            <div class="mt-3 rounded-xl border border-slate-200 bg-white overflow-hidden">
                                                <table class="w-full text-[11px]">
                                                    <thead class="bg-slate-50 text-slate-500">
                                                        <tr>
                                                            <th class="px-3 py-2 text-left">Fee Item</th>
                                                            <th class="px-3 py-2 text-center">Term</th>
                                                            <th class="px-3 py-2 text-right">Amount</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="divide-y divide-slate-100">
                                                        <tr>
                                                            <td colspan="3" class="px-3 py-8 text-center text-slate-400">
                                                                <i class="fas fa-receipt text-2xl mb-2"></i>
                                                                <p>No fee items selected</p>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                    <tfoot class="bg-slate-50">
                                                        <tr>
                                                            <td colspan="2" class="px-3 py-2 text-right text-[11px] font-medium text-slate-700">Total Paid</td>
                                                            <td class="px-3 py-2 text-right text-[12px] font-semibold text-emerald-600">K 0.00</td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>

                                            <div class="mt-3 flex items-start justify-between gap-3">
                                                <div class="text-[10px] text-slate-500 leading-snug">
                                                    <p>Thank you for your payment. Please keep this receipt for your records.</p>
                                                    <p class="mt-1">For any queries, contact the school accounts office.</p>
                                                </div>
                                                <div class="text-right text-[10px] text-slate-500">
                                                    <div class="mt-4 border-t border-slate-300 pt-1">
                                                        <div class="font-medium text-slate-700">Authorised Signatory</div>
                                                        <div class="text-[9px] text-slate-400 mt-1" data-authorised-signatory>Accountant</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>

                        <!-- Payment History -->
                        <section x-show="activeTab === 'payment-history'" x-cloak>
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-5">
                                    <div class="flex-1 space-y-4">
                                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                                            <div>
                                                <div class="text-sm font-semibold text-slate-800">Payment History</div>
                                                <div class="text-xs text-slate-400 mt-1">Complete record of all fee payments</div>
                                            </div>
                                            <div class="flex gap-2">
                                                <select class="px-3 py-1.5 rounded-xl border border-slate-200 bg-slate-50 text-xs" aria-label="Payment history filter" title="Payment history filter">
                                                    <option>All Time</option>
                                                    <option>This Month</option>
                                                    <option>Last Month</option>
                                                    <option>This Year</option>
                                                </select>
                                                <button class="px-3 py-1.5 rounded-xl bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700" onclick="exportData('csv', 'payment-history')">
                                                    <i class="fas fa-download mr-1"></i> Export CSV
                                                </button>
                                                <button class="px-3 py-1.5 rounded-xl bg-blue-600 text-white text-xs font-medium hover:bg-blue-700" onclick="exportData('pdf', 'payment-history')">
                                                    <i class="fas fa-file-pdf mr-1"></i> Export PDF
                                                </button>
                                            </div>
                                        </div>
                                        <div class="rounded-2xl border border-slate-100 overflow-hidden text-xs">
                                            <div class="hidden md:grid grid-cols-12 bg-slate-50 px-4 py-2.5 text-[11px] font-medium text-slate-500">
                                                <div class="col-span-2">Date</div>
                                                <div class="col-span-3">Student</div>
                                                <div class="col-span-2">Type</div>
                                                <div class="col-span-2">Amount</div>
                                                <div class="col-span-2">Method</div>
                                                <div class="col-span-1">Status</div>
                                            </div>
                                            <div id="fee-payment-history" class="divide-y divide-slate-100">
                                                <div class="text-center py-12">
                                                    <i class="fas fa-history text-4xl text-slate-300 mb-3"></i>
                                                    <p class="text-sm text-slate-500">No payment history recorded</p>
                                                    <p class="text-xs text-slate-400 mt-1">Payment history will appear here when payments are recorded</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Add Fee Type Modal -->
    <div id="add-fee-type-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
        <div class="bg-white rounded-2xl p-6 w-full max-w-md">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-semibold text-slate-800">Add Fee Type</h3>
                <button type="button" onclick="closeAddFeeTypeModal()" class="text-slate-400 hover:text-slate-600">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <form id="add-fee-type-form">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Fee Type Name *</label>
                        <input type="text" id="fee-type-name" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400" placeholder="e.g., Tuition Fees">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Grade Level</label>
                        <select id="fee-type-grade" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400">
                            <option value="">All Grades</option>
                            <option value="Grade 1">Grade 1</option>
                            <option value="Grade 2">Grade 2</option>
                            <option value="Grade 3">Grade 3</option>
                            <option value="Grade 4">Grade 4</option>
                            <option value="Grade 5">Grade 5</option>
                            <option value="Grade 6">Grade 6</option>
                            <option value="Grade 7">Grade 7</option>
                            <option value="Grade 8">Grade 8</option>
                            <option value="Grade 9">Grade 9</option>
                            <option value="Grade 10">Grade 10</option>
                            <option value="Grade 11">Grade 11</option>
                            <option value="Grade 12">Grade 12</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Amount *</label>
                        <input type="number" id="fee-type-amount" required step="0.01" min="0" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400" placeholder="0.00">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Frequency</label>
                        <select id="fee-type-frequency" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400">
                            <option value="Monthly">Monthly</option>
                            <option value="Termly">Termly</option>
                            <option value="Annually">Annually</option>
                            <option value="One-time">One-time</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-1">Description</label>
                        <textarea id="fee-type-description" rows="3" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm focus:outline-none focus:ring-1 focus:ring-emerald-400" placeholder="Optional description"></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" onclick="closeAddFeeTypeModal()" class="px-4 py-2 rounded-xl border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">Cancel</button>
                    <button type="submit" class="px-4 py-2 rounded-xl bg-emerald-600 text-white hover:bg-emerald-700">Add Fee Type</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Invoice Print Modal (3 copies) -->
    <div id="invoice-print-modal" class="fixed inset-0 bg-white z-50 hidden overflow-auto">
        <div class="min-h-screen p-8">
            <div class="max-w-4xl mx-auto">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-slate-800">Fee Invoice Copies</h2>
                    <div class="flex gap-3">
                        <button onclick="window.print()" class="px-4 py-2 rounded-xl bg-emerald-600 text-white hover:bg-emerald-700">
                            <i class="fas fa-print mr-2"></i> Print All Copies
                        </button>
                        <button onclick="closeInvoicePrintModal()" class="px-4 py-2 rounded-xl border border-slate-200 bg-white text-slate-600 hover:bg-slate-50">
                            <i class="fas fa-times mr-2"></i> Close
                        </button>
                    </div>
                </div>
                
                <!-- Pupil Copy -->
                <div class="bg-white border-2 border-slate-300 rounded-lg p-6 mb-8 page-break">
                    <div class="text-center mb-4">
                        <h3 class="text-lg font-bold text-slate-800">PUPIL COPY</h3>
                    </div>
                    <div id="pupil-copy-content">
                        <!-- Invoice content will be populated here -->
                    </div>
                </div>

                <!-- Bank Copy -->
                <div class="bg-white border-2 border-slate-300 rounded-lg p-6 mb-8 page-break">
                    <div class="text-center mb-4">
                        <h3 class="text-lg font-bold text-slate-800">BANK COPY</h3>
                    </div>
                    <div id="bank-copy-content">
                        <!-- Invoice content will be populated here -->
                    </div>
                </div>

                <!-- School Copy -->
                <div class="bg-white border-2 border-slate-300 rounded-lg p-6 page-break">
                    <div class="text-center mb-4">
                        <h3 class="text-lg font-bold text-slate-800">SCHOOL COPY</h3>
                    </div>
                    <div id="school-copy-content">
                        <!-- Invoice content will be populated here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        (function () {
            document.addEventListener('DOMContentLoaded', function () {
                try {
                    var select = document.getElementById('invoice-students-select');
                    if (!select || !window.ShikolaPupilsApi) return;

                    function getPupilsList() {
                        if (typeof window.ShikolaPupilsApi.listPupils === 'function') {
                            return window.ShikolaPupilsApi.listPupils();
                        }
                        if (typeof window.ShikolaPupilsApi.getLocalPupils === 'function') {
                            return Promise.resolve(window.ShikolaPupilsApi.getLocalPupils() || []);
                        }
                        return Promise.resolve([]);
                    }

                    getPupilsList().then(function (list) {
                        if (!Array.isArray(list) || !list.length) return;

                        var classMap = {};
                        list.forEach(function (p) {
                            if (!p) return;
                            var cls = '';
                            try {
                                if (window.ShikolaPupilsHelpers && typeof window.ShikolaPupilsHelpers.getClassLabel === 'function') {
                                    cls = window.ShikolaPupilsHelpers.getClassLabel(p) || '';
                                } else {
                                    cls = p.classGrade || p.classLabel || p.className || '';
                                }
                            } catch (e) {
                                cls = p.classGrade || p.classLabel || p.className || '';
                            }
                            if (!cls) {
                                cls = 'Unassigned';
                            }
                            classMap[cls] = true;
                        });

                        var classes = Object.keys(classMap).sort();
                        if (!classes.length) return;

                        while (select.options.length > 1) {
                            select.remove(1);
                        }

                        classes.forEach(function (cls) {
                            var opt = document.createElement('option');
                            opt.value = 'class:' + cls;
                            opt.textContent = 'All Students - ' + cls;
                            select.appendChild(opt);
                        });

                        var individual = document.createElement('option');
                        individual.value = 'individual';
                        individual.textContent = 'Individual Students';
                        select.appendChild(individual);
                    }).catch(function () {
                    });
                } catch (e) {
                }
            });
        })();
    </script>
    
</body>
</html>
